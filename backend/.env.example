# Server
PORT=3000

# Database
DB_PATH=./data/store.db

# Admin auth
ADMIN_API_KEY=your-secret-api-key-here

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=tick-app-store
R2_PUBLIC_URL=  # Optional: public bucket URL (skip presigned URLs)

# Store app self-update
STORE_APP_VERSION_NAME=1.0.0
STORE_APP_VERSION_CODE=1
STORE_APP_APK_KEY=store/tick-app-store.apk
